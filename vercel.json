{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/public/CSS/$1"
    },
    {
      "src": "/PHJSP/(.*)",
      "dest": "/public/PHJSP/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
